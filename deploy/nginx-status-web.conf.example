# =============================================================================
# Nginx → proxy al panel BetBot (127.0.0.1:8765)
#
# Requisito: el panel debe estar corriendo en la VM:
#   ./deploy/manage.sh dashboard-start
#   sudo systemctl status betbot-status-web
#
# Instalación típica (Ubuntu):
#   sudo apt install nginx
#   sudo cp deploy/nginx-status-web.conf.example /etc/nginx/sites-available/betbot-status
#
# IMPORTANTE — Si ves "Welcome to nginx!" al abrir la IP en el navegador:
#   El sitio por defecto sigue ganando. Quitá el default UNA vez:
#     sudo rm /etc/nginx/sites-enabled/default
#   Este archivo ya usa default_server para que betbot-status atienda el puerto 80.
#
#   sudo ln -sf /etc/nginx/sites-available/betbot-status /etc/nginx/sites-enabled/betbot-status
#   sudo nginx -t && sudo systemctl reload nginx
#
# Si ves 502 Bad Gateway: betbot-status-web no está activo o no escucha en 8765.
#   journalctl -u betbot-status-web -n 30 --no-pager
#
# Opcional — basic auth:
#   sudo apt install apache2-utils
#   sudo htpasswd -c /etc/nginx/.htpasswd-betbot tu_usuario
#   Descomentá las dos líneas "auth_basic" abajo.
# =============================================================================

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location / {
        # auth_basic           "BetBot";
        # auth_basic_user_file /etc/nginx/.htpasswd-betbot;

        proxy_pass         http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
