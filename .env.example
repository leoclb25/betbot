# ── Polymarket CLOB API ──────────────────────────────────────────────────────
# Obtain from: https://polymarket.com → Account → API Keys
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Your Polygon wallet private key (for signing orders in live mode)
# NEVER commit this value. Keep it only in .env (which is gitignored).
POLY_PRIVATE_KEY=0xyour_private_key_here

# Chain: 137 = Polygon Mainnet, 80002 = Amoy Testnet
POLY_CHAIN_ID=137

# ── Mode ─────────────────────────────────────────────────────────────────────
# "paper" = simulate with $100 virtual, "live" = real wallet
BOT_MODE=paper
PAPER_INITIAL_BALANCE=100.0

# ── Risk ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: NO poner comentarios inline. systemd no los strippea
# y rompe el parsing (KEY=valor  # comentario → ValueError).

# minimum edge after fees to enter a position
MIN_EDGE=0.08
# fraction of full Kelly to use (25% = conservative)
KELLY_FRACTION=0.25
# max portfolio % per position
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=6
# max total portfolio exposed at once
MAX_PORTFOLIO_RISK=0.35
# cap de nuevas entradas por ciclo (evita ráfaga en arranque)
MAX_ENTRIES_PER_CYCLE=2
# pause trading if daily loss exceeds this %
DAILY_LOSS_LIMIT=0.10
# pause trading if drawdown from peak exceeds this %
DRAWDOWN_LIMIT=0.25
# exit position if it loses this % of entry value
STOP_LOSS_PCT=0.40
# exit early if profit captures this % of theoretical max
TAKE_PROFIT_PCT=0.40
# filtro de precio: ignora mercados con YES < 5% o YES > 95% (mercados rotos/abandonados)
MIN_MARKET_PRICE=0.05
MAX_MARKET_PRICE=0.95

# ── Strategy ─────────────────────────────────────────────────────────────────
MIN_DAYS_TO_RESOLUTION=0
MAX_DAYS_TO_RESOLUTION=5
# ignore markets with less liquidity
MIN_LIQUIDITY_USD=1000
# minimum position size (below this, fees eat profits)
MIN_POSITION_USD=5.0

# ── Scheduling ────────────────────────────────────────────────────────────────
# how often to scan for new opportunities (1h)
SCAN_INTERVAL_SECONDS=3600

# ── Open-Meteo (ensemble / geocoding) ────────────────────────────────────────
# Intervalo mínimo entre llamadas al ensemble; tras un 429 se aplica POST_429_COOLDOWN extra.
OPEN_METEO_ENSEMBLE_MIN_INTERVAL=2.25
OPEN_METEO_ENSEMBLE_MAX_RETRIES=6
OPEN_METEO_GEOCODE_MIN_INTERVAL=0.4
OPEN_METEO_POST_429_COOLDOWN_SEC=22

# ── Weather bot (portfolio separado) ─────────────────────────────────────────
WEATHER_PAPER_INITIAL_BALANCE=100.0

# ── Crypto bot ────────────────────────────────────────────────────────────────
CRYPTO_PAPER_INITIAL_BALANCE=100.0

CRYPTO_MIN_EDGE=0.04
CRYPTO_KELLY_FRACTION=0.25
CRYPTO_MAX_POSITION_PCT=0.03
CRYPTO_MAX_OPEN_POSITIONS=4
CRYPTO_MAX_PORTFOLIO_RISK=0.20
CRYPTO_MAX_ENTRIES_PER_CYCLE=1
CRYPTO_DAILY_LOSS_LIMIT=0.08
CRYPTO_DRAWDOWN_LIMIT=0.20
CRYPTO_STOP_LOSS_PCT=0.35
CRYPTO_TAKE_PROFIT_PCT=0.50
CRYPTO_MIN_POSITION_USD=5.0
CRYPTO_MIN_MARKET_PRICE=0.05
CRYPTO_MAX_MARKET_PRICE=0.95

CRYPTO_SCAN_INTERVAL_SECONDS=300
CRYPTO_MAX_MINUTES_TO_RESOLUTION=60
CRYPTO_MIN_LIQUIDITY_USD=500

BTC_VOLATILITY_PER_MIN=0.0006
ETH_VOLATILITY_PER_MIN=0.0008
BINANCE_RATE_LIMIT_SECONDS=1.0
