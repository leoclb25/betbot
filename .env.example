# ── Polymarket CLOB API ──────────────────────────────────────────────────────
# Obtain from: https://polymarket.com → Account → API Keys
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Your Polygon wallet private key (for signing orders in live mode)
# NEVER commit this value. Keep it only in .env (which is gitignored).
POLY_PRIVATE_KEY=0xyour_private_key_here

# Chain: 137 = Polygon Mainnet, 80002 = Amoy Testnet
POLY_CHAIN_ID=137

# ── Mode ─────────────────────────────────────────────────────────────────────
# "paper" = simulate with $100 virtual, "live" = real wallet
BOT_MODE=paper
PAPER_INITIAL_BALANCE=100.0

# ── Risk ─────────────────────────────────────────────────────────────────────
MIN_EDGE=0.05           # minimum edge after fees to enter a position (5%)
KELLY_FRACTION=0.25     # fraction of full Kelly to use (25%)
MAX_POSITION_PCT=0.08   # max portfolio % per position (8%)
MAX_OPEN_POSITIONS=10
MAX_PORTFOLIO_RISK=0.50 # max total portfolio exposed at once (50%)
DAILY_LOSS_LIMIT=0.10   # pause trading if daily loss exceeds 10%
DRAWDOWN_LIMIT=0.25     # pause trading if drawdown from peak exceeds 25%
STOP_LOSS_PCT=0.40      # exit position if it loses 40% of entry value
TAKE_PROFIT_PCT=0.40    # exit early if profit captures 40%+ of theoretical max

# ── Strategy ─────────────────────────────────────────────────────────────────
MIN_DAYS_TO_RESOLUTION=0
MAX_DAYS_TO_RESOLUTION=7
MIN_LIQUIDITY_USD=500   # ignore markets with less liquidity
MIN_POSITION_USD=5.0    # minimum position size (below this, fees eat profits)

# ── Scheduling ────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=3600  # how often to scan for new opportunities (1h)
